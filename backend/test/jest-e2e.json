{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "__tests__/tasks/e2e/.*spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@prisma/client$": "<rootDir>/__mocks__/prisma-client"
  },
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
}
